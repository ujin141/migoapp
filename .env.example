# ─── Migo App 환경변수 ───────────────────────────────────────
# 이 파일을 .env.local 로 복사하고 실제 값을 채워주세요.
# .env.local 은 .gitignore 에 포함되어 있어 Git에 업로드되지 않습니다.
# Vercel 배포 시 동일 변수를 Vercel Dashboard에서도 설정해야 합니다.

# ── Supabase (필수) ──────────────────────────────────────────
# https://supabase.com → Project Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# ── OpenAI (번역 기능) ───────────────────────────────────────
# https://platform.openai.com/api-keys 에서 발급
VITE_OPENAI_API_KEY=sk-proj-YOUR_OPENAI_KEY

# ── Google Maps (지도 기능, 선택) ────────────────────────────
# https://console.cloud.google.com 에서 Maps JavaScript API 활성화 후 발급
VITE_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_KEY

# ── Admin 대시보드 PIN ────────────────────────────────────────
# 기본값 "migo2024"는 배포 전 반드시 변경하세요!
VITE_ADMIN_PIN=YOUR_STRONG_ADMIN_PIN

# ── Twilio SMS 인증 (Edge Function 환경변수로 설정) ─────────────
# ⚠️ 아래 값들은 절대 프론트엔드에 넣지 마세요!
# Supabase Dashboard → Edge Functions → twilio-send-otp / twilio-verify-otp → Secrets에서 설정
# https://console.twilio.com → Dashboard
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
